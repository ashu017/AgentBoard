# AgentBoard — environment (copy to .env.local and fill in)
# .env.local is gitignored. NEVER commit real keys.

# --- Supabase (new API key system: sb_publishable_ / sb_secret_) ---
# From your Supabase project: Settings → API.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# Publishable key (sb_publishable_...) — browser-safe; RLS protects the data.
# Must be NEXT_PUBLIC_ so the client board can use it.
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Secret key (sb_secret_...) — SERVER ONLY. Bypasses RLS. Used by the agent/MCP
# write path. Never expose to the client / never prefix with NEXT_PUBLIC_.
SUPABASE_SECRET_KEY=sb_secret_...

# --- MCP agent auth (S0: a single shared spike token) ---
AGENT_SPIKE_TOKEN=choose-a-long-random-string

# --- App ---
# Public origin (used to build the MCP endpoint URL shown in the agent onboarding
# snippet). e.g. https://your-app.vercel.app  (local: http://localhost:3100)
NEXT_PUBLIC_APP_ORIGIN=https://your-app.vercel.app

# DEV-ONLY local login shim (Phase 3). NEVER set in production — real auth is
# GitHub OAuth. Set to 1 only for local development.
# DEV_LOGIN=1
