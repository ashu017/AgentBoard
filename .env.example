# AgentBoard — environment (copy to .env.local and fill in)
# .env.local is gitignored. NEVER commit real keys.

# --- Supabase ---
# From your Supabase project: Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
# Public anon key — safe in the browser; RLS protects the data.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service-role key — SERVER ONLY. Bypasses RLS. Used by the agent/MCP write
# path (the confined agent-db module). Never expose to the client / never
# prefix with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- MCP agent auth (S0: a single shared spike token) ---
# In v1 this becomes a per-agent hashed key. For the S0 spike, one bearer
# token the test MCP client presents.
AGENT_SPIKE_TOKEN=choose-a-long-random-string
